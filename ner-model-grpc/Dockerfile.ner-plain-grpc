# Customer's plain gRPC NER model server — no Chalk dependencies.
#
# Build:
#   docker build --platform linux/amd64 -f Dockerfile.ner-plain-grpc -t ner-plain-grpc .

FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir spacy grpcio
RUN python -m spacy download en_core_web_sm

COPY ner_server_plain_grpc.py .

EXPOSE 9000

CMD ["python", "ner_server_plain_grpc.py"]
